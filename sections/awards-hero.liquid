{%- liquid
  assign hero_image = section.settings.image_asset | default: 'awards-hero.png'
-%}

<section id="AwardsHero-{{ section.id }}" class="awards-hero color-{{ section.settings.color_scheme }}">
  <div class="awards-hero__media">
    <img
      src="{{ hero_image | asset_url }}"
      alt="{{ section.settings.image_alt | escape }}"
      width="1672"
      height="930"
      loading="eager"
      fetchpriority="high"
    >
  </div>

  <div class="awards-hero__shade" aria-hidden="true"></div>

  <div class="awards-hero__content page-width">
    <div class="awards-hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="awards-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="awards-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="awards-hero__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      <div class="awards-hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a
            class="button button--primary"
            {% if section.settings.button_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.button_link }}"
            {% endif %}
          >
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}

        {%- if section.settings.button_label_2 != blank -%}
          <a
            class="button button--secondary"
            {% if section.settings.button_link_2 == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.button_link_2 }}"
            {% endif %}
          >
            {{ section.settings.button_label_2 | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% style %}
  #AwardsHero-{{ section.id }} {
    min-height: clamp(560px, 68vw, 760px);
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #08111a;
  }

  #AwardsHero-{{ section.id }} .awards-hero__media {
    position: absolute;
    inset: 0;
  }

  #AwardsHero-{{ section.id }} .awards-hero__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center right;
  }

  #AwardsHero-{{ section.id }} .awards-hero__shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(4, 10, 17, 0.96) 0%, rgba(4, 10, 17, 0.78) 31%, rgba(4, 10, 17, 0.18) 62%, rgba(4, 10, 17, 0) 100%),
      linear-gradient(0deg, rgba(4, 10, 17, 0.78) 0%, rgba(4, 10, 17, 0) 38%);
  }

  #AwardsHero-{{ section.id }} .awards-hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-top: 7rem;
    padding-bottom: 7rem;
  }

  #AwardsHero-{{ section.id }} .awards-hero__copy {
    max-width: 58rem;
    color: #ffffff;
  }

  #AwardsHero-{{ section.id }} .awards-hero__eyebrow {
    margin: 0 0 1.2rem;
    color: #d7b46a;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  #AwardsHero-{{ section.id }} .awards-hero__heading {
    margin: 0;
    color: #ffffff;
    font-size: clamp(4rem, 6vw, 7.4rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  #AwardsHero-{{ section.id }} .awards-hero__text {
    max-width: 52rem;
    margin-top: 2rem;
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.8rem;
    line-height: 1.55;
  }

  #AwardsHero-{{ section.id }} .awards-hero__text p {
    margin: 0;
  }

  #AwardsHero-{{ section.id }} .awards-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    margin-top: 3rem;
  }

  #AwardsHero-{{ section.id }} .button--secondary {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
    border: 0.1rem solid rgba(255, 255, 255, 0.5);
  }

  @media screen and (max-width: 749px) {
    #AwardsHero-{{ section.id }} {
      min-height: 64rem;
      align-items: flex-start;
    }

    #AwardsHero-{{ section.id }} .awards-hero__media img {
      object-position: 64% center;
    }

    #AwardsHero-{{ section.id }} .awards-hero__shade {
      background:
        linear-gradient(180deg, rgba(4, 10, 17, 0.98) 0%, rgba(4, 10, 17, 0.78) 42%, rgba(4, 10, 17, 0.18) 100%),
        linear-gradient(90deg, rgba(4, 10, 17, 0.7) 0%, rgba(4, 10, 17, 0.08) 100%);
    }

    #AwardsHero-{{ section.id }} .awards-hero__content {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }

    #AwardsHero-{{ section.id }} .awards-hero__copy {
      max-width: 37rem;
    }

    #AwardsHero-{{ section.id }} .awards-hero__heading {
      font-size: clamp(3.6rem, 12vw, 5rem);
    }

    #AwardsHero-{{ section.id }} .awards-hero__text {
      font-size: 1.6rem;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Awards hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "image_asset",
      "label": "Image asset filename",
      "default": "awards-hero.png"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Crystal trophies and engraved plaques displayed on a dark marble surface"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Custom awards and recognition gifts"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Honor every achievement with a lasting award"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Celebrate your team, clients, students, and standout performers with beautifully crafted trophies, plaques, crystal awards, and personalized recognition gifts made to feel as meaningful as the moment.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "First button label",
      "default": "Shop Awards"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "First button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Second button label",
      "default": "Request a Quote"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Second button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    }
  ],
  "presets": [
    {
      "name": "Awards hero"
    }
  ]
}
{% endschema %}
